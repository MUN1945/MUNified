generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================
// ENUMS
// ============================

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  SCHOOL_ADMIN
  SUPER_ADMIN
  FOUNDER
  MASTER_ADMIN
}

enum MUNRole {
  SECRETARY_GENERAL
  DIRECTOR_GENERAL
  CHAIR
  DELEGATE
  DELEGATE_ADVANCED
  SDG_AMBASSADOR
  RAPPORTEUR
}

enum SubscriptionTier {
  FREE
  DELEGATE_PRO
  DIRECTOR_PRO
  SCHOOL_STARTER
  SCHOOL_PROFESSIONAL
  SCHOOL_ENTERPRISE
  CONFERENCE_PACKAGE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ConferenceStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CommitteeType {
  GENERAL_ASSEMBLY
  SECURITY_COUNCIL
  ECOSOC
  SPECIALIZED_AGENCY
  CRISIS_COMMITTEE
  HISTORICAL_COMMITTEE
  INTERNATIONAL_COURT
  HUMAN_RIGHTS_COUNCIL
  DISARMAMENT_COMMITTEE
  WORLD_HEALTH_ASSEMBLY
}

enum AssessmentType {
  DIAGNOSTIC
  SKILL_EVALUATION
  ROLE_PLACEMENT
  PROGRESS_CHECK
  PRE_CONFERENCE
  TIER_ADVANCEMENT
}

enum AssessmentTier {
  TIER_1_BASIC_DELEGATE
  TIER_2_ADVANCED_DELEGATE
  TIER_3_COMMITTEE_LEADER
  TIER_4_CHAIR
  TIER_5_UNDER_SECRETARY_GENERAL
  TIER_6_DEPUTY_SECRETARY_GENERAL
  TIER_7_SECRETARY_GENERAL
}

enum BadgeCategory {
  PARTICIPATION
  ACHIEVEMENT
  LEADERSHIP
  SKILL_MASTERY
  MILESTONE
  SPECIAL
  DIPLOMACY
  ORATORY
}

enum XPLevel {
  OBSERVER
  DELEGATE
  AMBASSADOR
  DIPLOMAT
  ENVOY
  SECRETARY_GENERAL
}

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  PERMISSION_CHANGE
}

enum SchoolType {
  PUBLIC
  PRIVATE
  INTERNATIONAL
  CHARTER
}

enum Curriculum {
  AMERICAN
  BRITISH
  IB
  CBSE
  NATIONAL
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuestionType {
  MULTIPLE_CHOICE
  SCENARIO
  SIMULATION
  SPEECH_EVAL
  WRITING
  LEADERSHIP
  RESEARCH_TASK
  AI_INTERVIEW
}

enum QuestionCategory {
  KNOWLEDGE
  SKILLS
  BEHAVIOR
}

enum PaperStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  EVALUATED
  RETURNED
}

enum SecurityEventType {
  LOGIN
  LOGOUT
  FAILED_LOGIN
  PASSWORD_CHANGE
  SUSPICIOUS_ACTIVITY
  RATE_LIMIT_HIT
  API_ABUSE
  SESSION_EXPIRED
}

enum SecurityEventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ConferencePackageType {
  PAY_PER_EVENT
  ANNUAL_LICENSE
}

// ============================
// MODELS
// ============================

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  name               String
  password           String
  avatar             String?
  role               UserRole          @default(STUDENT)
  munRole            MUNRole?
  bio                String?
  phone              String?
  country            String            @default("UAE")
  city               String?
  language           String            @default("en")
  schoolId           String?
  isActive           Boolean           @default(true)
  isBot              Boolean           @default(false)
  emailVerified      Boolean           @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  school                  School?                     @relation(fields: [schoolId], references: [id])
  subscription            Subscription?
  delegateProfile         DelegateProfile?
  conferenceRegistrations ConferenceRegistration[]
  assessments             Assessment[]
  badges                  UserBadge[]
  courseEnrollments       CourseEnrollment[]
  messages                Message[]
  activities              Activity[]
  auditLogs               AuditLog[]
  researchTasks           ResearchTask[]
  researchAssignments     ResearchTask[]              @relation("AssignedTasks")
  chairedCommittees       Committee[]
  sentNotifications       Notification[]              @relation("SentTo")
  paymentRecords          Payment[]
  invoices                Invoice[]
  researchPapers          ResearchPaper[]
  supervisedPapers        ResearchPaper[]             @relation("PaperTeacher")
  securityEvents          SecurityEvent[]
  sessions                Session[]

  @@index([schoolId])
  @@index([role])
  @@index([email])
  @@index([isActive])
}

model School {
  id                String            @id @default(cuid())
  name              String
  officialName      String?
  location          String?
  city              String?
  emirate           String?
  country           String            @default("UAE")
  region            String?           // GCC/International
  website           String?
  logo              String?
  description       String?
  contactEmail      String?
  contactPhone      String?
  contactPerson     String?
  schoolType        SchoolType?
  curriculum        Curriculum?
  gradeRange        String?           // e.g., "K-12"
  studentCount      Int               @default(0)
  teacherCount      Int               @default(0)
  isVerified        Boolean           @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  isFeatured        Boolean           @default(false)
  source            String?           // MANUAL, GOVERNMENT_API, SELF_REGISTERED, ADMIN_CREATED
  latitude          Float?
  longitude         Float?
  munProgramActive  Boolean           @default(false)
  munProgramSize    Int               @default(0)
  isOtherSchool     Boolean           @default(false)  // Special flag for "Other School" option
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  users                   User[]
  conferences             Conference[]
  schoolSubscriptions     SchoolSubscription[]
  verificationRequests    SchoolVerificationRequest[]

  @@index([name])
  @@index([country])
  @@index([city])
  @@index([verificationStatus])
  @@index([isFeatured])
  @@index([schoolType])
}

model SchoolVerificationRequest {
  id            String            @id @default(cuid())
  schoolId      String
  requestedBy   String
  status        VerificationStatus @default(PENDING)
  documents     String?           // JSON array of document URLs
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@index([requestedBy])
}

model Subscription {
  id                String            @id @default(cuid())
  userId            String            @unique
  tier              SubscriptionTier  @default(FREE)
  status            SubscriptionStatus @default(TRIAL)
  lemonsqueezyCustomerId    String?
  lemonsqueezyVariantId     String?
  lemonsqueezySubscriptionId String?
  trialStartsAt     DateTime?
  trialEndsAt       DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([status])
  @@index([lemonsqueezyCustomerId])
}

model SchoolSubscription {
  id                String            @id @default(cuid())
  schoolId          String
  tier              SubscriptionTier  @default(SCHOOL_ENTERPRISE)
  status            SubscriptionStatus @default(TRIAL)
  maxStudents       Int               @default(50)
  maxTeachers       Int               @default(5)
  lemonsqueezyCustomerId    String?
  lemonsqueezySubscriptionId String?
  trialEndsAt       DateTime?
  currentPeriodEnd  DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([status])
}

model Conference {
  id          String           @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  status      ConferenceStatus @default(DRAFT)
  logo        String?
  website     String?
  theme       String?
  schoolId    String?
  createdBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  school        School?                 @relation(fields: [schoolId], references: [id])
  committees    Committee[]
  registrations ConferenceRegistration[]
  activities    Activity[]

  @@index([status])
  @@index([startDate])
  @@index([schoolId])
}

model Committee {
  id           String        @id @default(cuid())
  name         String
  description  String?
  type         CommitteeType @default(GENERAL_ASSEMBLY)
  topic        String?
  topicDescription String?
  countryLimit Int           @default(30)
  conferenceId String
  chairId      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  conference    Conference             @relation(fields: [conferenceId], references: [id])
  chair         User?                  @relation(fields: [chairId], references: [id], onDelete: SetNull)
  registrations ConferenceRegistration[]

  @@index([conferenceId])
  @@index([type])
}

model Assessment {
  id                 String         @id @default(cuid())
  userId             String
  type               AssessmentType @default(DIAGNOSTIC)
  currentTier        AssessmentTier @default(TIER_1_BASIC_DELEGATE)
  highestTierReached AssessmentTier @default(TIER_1_BASIC_DELEGATE)
  knowledgeScore     Int            @default(0)
  skillsScore        Int            @default(0)
  behaviorScore      Int            @default(0)
  confidenceScore    Int            @default(0)
  diplomacyScore     Int            @default(0)
  speakingScore      Int            @default(0)
  researchScore      Int            @default(0)
  leadershipScore    Int            @default(0)
  crisisManagementScore Int         @default(0)
  negotiationScore   Int            @default(0)
  procedureScore     Int            @default(0)
  writingScore       Int            @default(0)
  criticalThinkingScore Int         @default(0)
  collaborationScore Int            @default(0)
  debateScore        Int            @default(0)
  totalScore         Int            @default(0)
  passed             Boolean        @default(false)
  failedCheckpoints  Int            @default(0)
  maxFailedCheckpoints Int          @default(3)
  recommendedRole    String?
  recommendedTier    AssessmentTier?
  placementReport    String?        // JSON with detailed analysis
  answers            String?        // JSON
  completedAt        DateTime       @default(now())
  createdAt          DateTime       @default(now())

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses  AssessmentResponse[]

  @@index([userId])
  @@index([type])
  @@index([completedAt])
  @@index([currentTier])
}

model AssessmentQuestion {
  id           String        @id @default(cuid())
  tier         AssessmentTier
  questionType QuestionType
  category     QuestionCategory
  text         String
  options      String?       // JSON array
  correctAnswer String?
  explanation  String?
  difficulty   Int           @default(5)
  points       Int           @default(1)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())

  responses AssessmentResponse[]

  @@index([tier])
  @@index([questionType])
  @@index([category])
  @@index([isActive])
}

model AssessmentResponse {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String
  response     String
  isCorrect    Boolean?
  pointsEarned Int      @default(0)
  timeSpent    Int?     // in seconds
  createdAt    DateTime @default(now())

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id])

  @@index([assessmentId])
  @@index([questionId])
}

model Course {
  id          String           @id @default(cuid())
  title       String
  description String?
  category    String
  thumbnail   String?
  duration    Int?
  difficulty  CourseDifficulty @default(BEGINNER)
  xpReward    Int              @default(50)
  targetRole  String?
  order       Int              @default(0)
  isPublished Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  enrollments CourseEnrollment[]
  lessons     Lesson[]

  @@index([category])
  @@index([targetRole])
  @@index([isPublished])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  content     String?
  type        String   @default("reading")
  duration    Int?
  order       Int
  courseId    String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([order])
}

model Badge {
  id          String        @id @default(cuid())
  name        String
  description String?
  icon        String?
  image       String?
  category    BadgeCategory @default(ACHIEVEMENT)
  xpReward    Int           @default(0)
  requirement String?
  isHidden    Boolean       @default(false)
  createdAt   DateTime      @default(now())

  userBadges UserBadge[]

  @@index([category])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([earnedAt])
}

model DelegateProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  xp                  Int      @default(0)
  level               XPLevel  @default(OBSERVER)
  streak              Int      @default(0)
  longestStreak       Int      @default(0)
  lastActivityDate    DateTime?
  conferencesAttended Int      @default(0)
  committeesServed    Int      @default(0)
  awardsReceived      Int      @default(0)
  resolutionsWritten  Int      @default(0)
  speechesDelivered   Int      @default(0)
  country             String?
  preferredCommitteeType CommitteeType?
  bio                 String?
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([xp])
  @@index([level])
  @@index([streak])
}

model ConferenceRegistration {
  id           String   @id @default(cuid())
  userId       String
  conferenceId String
  committeeId  String?
  country      String?
  role         String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  conference Conference @relation(fields: [conferenceId], references: [id])
  committee  Committee? @relation(fields: [committeeId], references: [id])

  @@unique([userId, conferenceId])
  @@index([userId])
  @@index([conferenceId])
  @@index([status])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  progress    Float     @default(0)
  completed   Boolean   @default(false)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([completed])
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("general")
  category    String?  // Grouping: e.g., "General Assembly", "Security Council", "Regional Bodies"
  committeeId String?
  schoolId    String?
  isCommittee Boolean  @default(false) // True for standard MUN committee channels
  createdAt   DateTime @default(now())

  messages Message[]

  @@index([type])
  @@index([schoolId])
  @@index([category])
  @@index([isCommittee])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  channelId String
  userId    String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id])
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([userId])
  @@index([createdAt])
}

model ResearchTask {
  id          String   @id @default(cuid())
  schoolId    String?
  title       String
  description String
  assignedTo  String?
  dueDate     DateTime?
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee User?  @relation("AssignedTasks", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator  User?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
}

model Activity {
  id           String   @id @default(cuid())
  type         String
  description  String
  userId       String?
  conferenceId String?
  metadata     String?
  xpEarned     Int      @default(0)
  createdAt    DateTime @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  conference Conference? @relation(fields: [conferenceId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String   @default("info")
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  user User @relation("SentTo", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  amount            Float
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  lemonsqueezyOrderId String?
  lemonsqueezyInvoiceId String?
  description       String?
  metadata          String?
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  amount        Float
  currency      String        @default("USD")
  status        InvoiceStatus @default(DRAFT)
  invoiceNumber String        @unique
  description   String?
  dueDate       DateTime?
  paidAt        DateTime?
  lemonsqueezyInvoiceId String?
  pdfUrl        String?
  metadata      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  resource  String
  resourceId String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float
  type        String   @default("percentage")
  maxUses     Int?
  usedCount   Int      @default(0)
  validFrom   DateTime @default(now())
  validUntil  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([isActive])
}

model PricingPlan {
  id           String           @id @default(cuid())
  name         String
  tier         SubscriptionTier
  priceMonthly Float
  priceYearly  Float?
  currency     String           @default("USD")
  features     String
  maxStudents  Int?
  maxTeachers  Int?
  isPopular    Boolean          @default(false)
  isActive     Boolean          @default(true)
  order        Int              @default(0)
  createdAt    DateTime         @default(now())

  @@index([tier])
  @@index([isActive])
}

// ============================
// CONFERENCE PACKAGE
// ============================

model ConferencePackage {
  id           String              @id @default(cuid())
  name         String
  type         ConferencePackageType
  priceMonthly Float?
  priceYearly  Float?
  currency     String              @default("USD")
  maxDelegates Int                 @default(0)
  maxCommittees Int                @default(0)
  features     String              // JSON
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())

  @@index([type])
  @@index([isActive])
}

// ============================
// RESEARCH PAPER EVALUATION SYSTEM
// ============================

model ResearchPaper {
  id          String      @id @default(cuid())
  studentId   String
  teacherId   String?
  title       String
  abstract    String?
  content     String?
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  status      PaperStatus @default(DRAFT)
  submittedAt DateTime?
  evaluatedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  student    User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    User?          @relation("PaperTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  evaluation PaperEvaluation?
  feedbacks  PaperFeedback[]

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([submittedAt])
}

model PaperEvaluation {
  id                     String   @id @default(cuid())
  paperId                String   @unique
  overallScore           Int      @default(0)
  strengths              String?  // JSON array
  weaknesses             String?  // JSON array
  recommendations        String?  // JSON array
  citationQualityScore   Int      @default(0)
  researchDepthScore     Int      @default(0)
  writingQualityScore    Int      @default(0)
  diplomacyRelevanceScore Int     @default(0)
  argumentQualityScore   Int      @default(0)
  analyticalThinkingScore Int     @default(0)
  aiContentPercentage    Float    @default(0)
  aiContentThreshold     Float    @default(25)
  aiDetectionDetails     String?  // JSON with detailed AI detection analysis
  originalityScore       Int      @default(0)
  authenticityScore      Int      @default(0)
  improvementRoadmap     String?  // JSON
  aiModel                String   @default("z-ai-v1")
  evaluatedAt            DateTime @default(now())
  createdAt              DateTime @default(now())

  paper     ResearchPaper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  feedbacks PaperFeedback[]

  @@index([paperId])
  @@index([overallScore])
}

model PaperFeedback {
  id                 String   @id @default(cuid())
  paperId            String
  evaluationId       String
  teacherId          String?
  teacherComments    String?
  teacherRating      Int      @default(0)
  aiSummary          String?  // condensed AI evaluation summary for teachers
  studentProgressTrend String? // JSON tracking progress over time
  createdAt          DateTime @default(now())

  paper      ResearchPaper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  evaluation PaperEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([evaluationId])
  @@index([teacherId])
}

// ============================
// SECURITY AUDIT MODELS
// ============================

model SecurityEvent {
  id            String              @id @default(cuid())
  userId        String?
  eventType     SecurityEventType
  ipAddress     String?
  userAgent     String?
  details       String?
  severity      SecurityEventSeverity @default(LOW)
  isResolved    Boolean             @default(false)
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([isActive])
}

// ============================
// PLATFORM METRICS (FOUNDER DASHBOARD)
// ============================

model PlatformMetric {
  id                   String   @id @default(cuid())
  date                 DateTime @unique
  totalSchools         Int      @default(0)
  totalTeachers        Int      @default(0)
  totalStudents        Int      @default(0)
  activeUsers          Int      @default(0)
  newRegistrations     Int      @default(0)
  churnedUsers         Int      @default(0)
  mrr                  Float    @default(0)
  arr                  Float    @default(0)
  activeSubscriptions  Int      @default(0)
  failedPayments       Int      @default(0)
  refunds              Int      @default(0)
  customerLifetimeValue Float   @default(0)
  createdAt            DateTime @default(now())

  @@index([date])
}

// ============================
// PASSWORD RESET & EMAIL VERIFICATION
// ============================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}
